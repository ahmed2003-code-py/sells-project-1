# Flask
SECRET_KEY=change-this-to-a-random-long-string-in-production
FLASK_DEBUG=0

# Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:port/dbname

# OR individual DB settings (if no DATABASE_URL)
DB_HOST=caboose.proxy.rlwy.net
DB_PORT=21778
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your-password-here

# Master V integration
MASTER_V_TOKEN=your-master-v-token

# First-run admin credentials (change immediately after deploy!)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Optional: disable background sync scheduler
DISABLE_SYNC=false

# App port (Railway provides PORT automatically)
PORT=8080
